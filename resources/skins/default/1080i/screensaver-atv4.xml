<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<window type="window">
    <controls>
    	<control type="image">
            <description>blackbackground</description>
            <posx>0</posx>
            <posy>0</posy>
            <colordiffuse>FF555555</colordiffuse>
            <aspectratio scalediffuse="false" align="center" aligny="center">scale</aspectratio>
            <width>1920</width>
            <height>1080</height>
            <texture>black.jpg</texture>
        </control>
        <control type="image" id="32500">
            <description>Background image</description>
            <posx>0</posx>
            <posy>0</posy>
            <colordiffuse>FF555555</colordiffuse>
            <aspectratio scalediffuse="false" align="center" aligny="center">scale</aspectratio>
            <width>1920</width>
            <height>1080</height>
            <texture>sanfrancisco.jpg</texture>
            <visible>!String.IsEqual(Window.Property(screensaver-atv4-loading),"false")</visible>
        </control>
		<control type="image" id ="32501">
				<description>Busy animation</description>
				<posx>40</posx>
				<posy>1000</posy>
				<width>30</width>
				<height>30</height>
				<texture>busy.png</texture>
				<aspectratio>keep</aspectratio>
				<animation effect="rotate" start="0" end="360" center="55,1015" time="1200" loop="true" condition="true">conditional</animation>
				<visible>!String.IsEqual(Window.Property(screensaver-atv4-loading),"false")</visible>
			</control>
		<control type="label" id ="32502">
				<top>975</top>
				<left>90</left>
				<width>600</width>
				<height>90</height>
				<font>font11</font>
				<textcolor>88FFFFFF</textcolor>
				<aligny>center</aligny>
				<align>left</align>
				<label></label>
				<visible>!String.IsEqual(Window.Property(screensaver-atv4-loading),"false")</visible>
		</control>
		<control type="label" id="32503">
				<top>975</top>
				<left>40</left>
				<width>600</width>
				<height>90</height>
				<font>font11</font>
				<textcolor>88FFFFFF</textcolor>
				<aligny>center</aligny>
				<align>left</align>
				<label></label>
		</control>
		<control type="videowindow">
			<description>VideoWindow</description>
		    <posx>0</posx>
		    <posy>0</posy>
		    <width>1920</width>
		    <height>1080</height>
		    <visible>true</visible>
		</control>
		<control type="grouplist" id="32504">
				<visible>String.IsEqual(Window.Property(show-info),true)</visible>
				<left>60</left>
				<bottom>60</bottom>
				<width>800</width>
				<!-- Expanded to 90 to hold the two taller labels -->
				<height>90</height> 
				<itemgap>0</itemgap>
				<orientation>vertical</orientation>
				<control type="label">
						<width>800</width>
						<!-- Expanded to 50 -->
						<height>50</height> 
						<font>font_head_bold</font> 
						<textcolor>FFFFFFFF</textcolor> 
						<shadowcolor>FF000000</shadowcolor> 
						<aligny>bottom</aligny>
						<align>left</align>
						<label>$INFO[Window.Property(AerialLocation)]</label>
				</control>
				<control type="label">
						<width>800</width>
						<!-- Expanded to 40 to protect the commas -->
						<height>40</height> 
						<font>font_main</font> 
						<textcolor>FFFFFFFF</textcolor> 
						<shadowcolor>FF000000</shadowcolor>
						<!-- Switched to top so it hugs the line above it -->
						<aligny>top</aligny> 
						<align>left</align>
						<label>$INFO[System.Date], $INFO[System.Time]</label>
				</control>
		</control>
   </controls>
</window>
